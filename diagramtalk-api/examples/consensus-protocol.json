        { "id": "agt-ack", "label": "Ack" },
        { "id": "agt-facts", "label": "Fact\nCollect" },
        { "id": "agt-discussion", "label": "Discussion" },
        { "id": "agt-proposal", "label": "Proposal" },
        { "id": "agt-endorsement", "label": "Endorsement\n(peer accepts)" },
