      ]
    },
    {
      "id": "errornotes",
      "type": "box",
      "color": "yellow",
      "fill": "semi",
      "nodes": [
        { "id": "agt-violation", "label": "Violation\nUnexpected message that is not a valid regression interrupts immediately." },
        { "id": "agt-regression", "label": "Regression\nLower-ranked message asks for confirmation. 2 retries, then interrupt." },
        { "id": "agt-fallback", "label": "Fallback\nOpinion instead of acceptance returns to Discussion. Allowed 2 times." },
        { "id": "agt-reject", "label": "User Reject\nPlan cleared, feedback sent, planning loop resumes." },
        { "id": "agt-timers", "label": "Timers\nFact collection 480s (Gemini 720s). Planning watchdog 900s. Submit urgency 120s x2. Agreement compliance 60s x2. Shutdown grace 60s." },
        { "id": "agt-refuse", "label": "Worker Refuse\nTask becomes refused / error." }
      ]
    },
    {
      "id": "rules",
      "type": "box",
      "color": "yellow",
      "fill": "semi",
      "nodes": [
        { "id": "agt-rule-initiator", "label": "Asymmetry rule\nFirst planner is initiator; peer waits and responds." },
        { "id": "agt-rule-endorser", "label": "Two-person check\nEndorser cannot submit; the other planner submits the plan." },
        { "id": "agt-save-marker", "type": "text", "color": "grey", "label": "saved AgentTalk diagram" }
      ]
    }
  ],
